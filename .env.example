# Copy ke .env dan isi seperlunya. Paper trading (default) TIDAK butuh kredensial apa pun.

# ── LIVE TRADING (opsional — kosongin buat paper trading) ─────────────────────
# Pakai wallet KHUSUS bot, isi cuma sejumlah budget yang direlain. JANGAN commit.
PRIVATE_KEY=
FUNDER_ADDRESS=

# ── GATE KEAMANAN (default paper) ─────────────────────────────────────────────
SIMULASI_MODE=true            # false = izinkan live (gate 1)
LIVE_TRADING_ENABLED=false    # true  = izinkan live (gate 2). DUA-DUANYA harus set
MAX_ORDER_SIZE_ABSOLUTE=5     # hard cap $ per order (gate 3)
BUDGET=100
MAX_PER_TRADE=5

# ── ALERT TELEGRAM (opsional) ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DASHBOARD VERCEL (opsional) — tiap event di-push ke sini buat dipantau live ─
POLYBOT_DASHBOARD_URL=

# ── NARASI AI (opsional; keputusan tetap deterministik tanpa ini) ─────────────
GROQ_API_KEY=

# ── COPY-TRADE ────────────────────────────────────────────────────────────────
COPYTRADE_ENABLED=true
SINGLE_TRADER_MODE=false      # true = copy 1 trader terbaik; false = consensus 2+
AUTO_PILIH_TRADER=true        # true = scan leaderboard; false = pakai TRADER_WALLETS
TRADER_WALLETS=               # dipisah koma, dipakai kalau AUTO_PILIH_TRADER=false
SKOR_THRESHOLD=5
MIN_WIN_RATE_PNL=55
MAX_HARI_KE_RESOLVE=90
COPYTRADE_AGGRESSIVE=false     # paper only: true = ikut bet banyak (anti skip mulu), buat kumpulin data
KELLY_ENABLED=true             # false = flat sizing (bet rata, gak diciutin Kelly)
FLAT_FRAC=0.5                  # fraksi flat size (0-1) × MAX_PER_TRADE saat Kelly off

# ── ARBITRAGE ─────────────────────────────────────────────────────────────────
ARB_ENABLED=true
ARB_MIN_EDGE_PCT=5            # buffer fee KASAR, bukan hitungan presisi
ARB_MIN_LIQUIDITY=500
ARB_SCAN_INTERVAL_MIN=5

# ── SCANNER ───────────────────────────────────────────────────────────────────
SCANNER_ENABLED=true
SCANNER_MIN_VOLUME=10000
SCANNER_CATEGORIES=sports,politics,crypto
SCANNER_INTERVAL_MIN=15
